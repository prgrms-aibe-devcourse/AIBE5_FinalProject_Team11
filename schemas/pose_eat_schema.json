{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yoga Pose E-E-A-T Schema",
  "type": "object",
  "required": ["pose_id", "canonical_name", "common_name", "difficulty_rank", "anatomical_focus", "educational_metadata", "matching_logic", "geo_keywords", "schema_org"],
  "properties": {
    "pose_id": {"type": "string", "description": "Unique pose identifier."},
    "canonical_name": {"type": "string"},
    "common_name": {"type": "string"},
    "difficulty_rank": {"type": "integer", "minimum": 1, "maximum": 5},
    "anatomical_focus": {
      "type": "array",
      "items": {"type": "string"}
    },
    "educational_metadata": {
      "type": "object",
      "properties": {
        "instructor_cue_priority": {"type": "string"},
        "lineage_source": {"type": "string"},
        "fyt100_session_ref": {"type": "string"},
        "aeo_summary": {"type": "string"}
      },
      "required": ["aeo_summary"]
    },
    "matching_logic": {
      "type": "object",
      "properties": {
        "benefits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tag": {"type": "string"},
              "weight": {"type": "number", "minimum": 0, "maximum": 1}
            },
            "required": ["tag", "weight"]
          }
        },
        "contraindications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition": {"type": "string"},
              "severity": {"type": "string", "enum": ["CAUTION", "CRITICAL", "MEDICAL_CLEARANCE"]},
              "kill_switch": {"type": "boolean"},
              "instruction": {"type": "string"}
            },
            "required": ["condition", "severity", "kill_switch", "instruction"]
          }
        }
      },
      "required": ["benefits", "contraindications"]
    },
    "geo_keywords": {
      "type": "array",
      "items": {"type": "string"}
    },
    "schema_org": {
      "type": "object"
    }
  }
}
