# Intermediate OCR output
ocr/raw/

# Python env
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key

# Keep processed + content + data
!ocr/processed/.gitkeep
!content/.gitkeep
!data/json/.gitkeep

# --- Orphan review: un-tracked 2026-04-21, pending deletion decision ---
# 166 OCR source screenshots (~25 MB of binary PNGs)
# Use Git LFS or object storage instead.
screenshots/*.png

# Generated data files — rebuild with: scripts/enrich_poses.py + generate_pose_insert_sql.py
data/poses/poses_eat_schema.json
data/poses/pose_enriched_ingest.sql

# Instructor scraper outputs — rebuild with: scripts/scrape_instructors.py
data/instructors/instructors_raw.json
data/instructors/instructors_seed.sql
# Keep the directory itself
!data/instructors/.gitkeep

# RAG indexes — rebuild with: scripts/rag_ingest.py --book <name>
data/rag/*.jsonl

# instaloader session files (contain auth tokens — never commit)
.instaloader/
*.instaloader-session

# Copilot / AI-generated status/log files
COPILOT_STATUS.md

# FastAPI / uvicorn logs
/tmp/*.log
*.log

# Node / frontend build artifacts (covered by frontend/.gitignore but belt-and-suspenders)
frontend/node_modules/
frontend/dist/
frontend/.env*
