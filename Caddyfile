# aeogeo / yogaman.club reverse proxy
# -----------------------------------------------------------------------------
# Public hostname:  match.yogaman.club  (DNS on Cloudflare → CF Tunnel → here)
# Local listener:   :8088  (cloudflared/dev clients connect to http://localhost:8088)
#                   Port 8080 is reserved on this host (jeju-presentation).
#
# elbee.yogaman.club is intentionally NOT served here — it remains a separate
# GitHub Pages Jekyll site (instructor brand portfolio). Do not collide.
# -----------------------------------------------------------------------------

{
	# Cloudflare terminates TLS — Caddy speaks plain HTTP to the tunnel.
	auto_https off
}

http://match.yogaman.club:8088, http://localhost:8088, http://:8088 {

	# Upstream alias — Docker resolves host.docker.internal to the host gateway,
	# which exposes everything the WSL host (and Docker Desktop VM) publishes.
	# /chat — conversational RAG (container yoga-chat-api → host port 5002)
	handle /chat* {
		reverse_proxy host.docker.internal:5002 {
			flush_interval -1            # keep SSE / streaming responses alive
			header_up X-Forwarded-Proto https
		}
	}

	# /search — Typesense-backed studio/instructor lookup (yoga-search-api → 5001)
	handle /search* {
		reverse_proxy host.docker.internal:5001
	}

	# /match — Streamlit match-score demo (when running locally on :8599)
	handle /match* {
		reverse_proxy host.docker.internal:8599
	}

	# /api/v1 — Spring Boot yoga-api (matching, studios, bookings) when present
	handle /api/v1* {
		reverse_proxy host.docker.internal:19090
	}

	# Provider surface — studio / instructor partner dashboard
	handle /partners* {
		reverse_proxy host.docker.internal:5002
	}
	handle /studio* {
		reverse_proxy host.docker.internal:5002
	}

	# AEO / SEO — static JSON-LD documents for crawlers (mounted into container)
	handle /.well-known/* {
		root * /srv/well-known
		file_server
	}
	handle /aeo/* {
		root * /srv/aeo
		file_server
	}

	handle /health {
		reverse_proxy host.docker.internal:5002
	}

	# Default — try Vite dev server (5173); fall back to chat API landing page
	handle /* {
		reverse_proxy host.docker.internal:5173 host.docker.internal:5002 {
			lb_try_duration 500ms
			fail_duration 5s
			transport http {
				dial_timeout 1s
			}
		}
	}

	encode zstd gzip

	log {
		output stderr
		format console
	}
}
