# aeogeo / yogaman.club reverse proxy
# -----------------------------------------------------------------------------
# Public hostname:  match.yogaman.club  (DNS on Cloudflare → CF Tunnel → here)
# Local listener:   :8088  (cloudflared/dev clients connect to http://localhost:8088)
#                   Port 8080 is reserved on this host (jeju-presentation).
#
# elbee.yogaman.club is intentionally NOT served here — it remains a separate
# GitHub Pages Jekyll site (instructor brand portfolio). Do not collide.
# -----------------------------------------------------------------------------

{
	# Cloudflare terminates TLS — Caddy speaks plain HTTP to the tunnel.
	auto_https off
}

http://match.yogaman.club:8088, http://localhost:8088, http://:8088 {

	# Upstream alias — Docker resolves host.docker.internal to the host gateway,
	# which exposes everything the WSL host (and Docker Desktop VM) publishes.
	# /chat — conversational RAG (FastAPI uvicorn on host :8000)
	handle /chat* {
		reverse_proxy host.docker.internal:8000 {
			flush_interval -1            # keep SSE / streaming responses alive
			header_up X-Forwarded-Proto https
		}
	}

	# /search — same FastAPI app on host :8000 (Typesense path mounted there)
	handle /search* {
		reverse_proxy host.docker.internal:8000
	}

	# /match — POST requests go to Spring Boot yoga-api (rewritten to /api/v1/match)
	#          GET requests fall through to the React frontend via handle /*
	@matchPost {
		path /match*
		method POST
	}
	handle @matchPost {
		rewrite * /api/v1{path}
		reverse_proxy host.docker.internal:19090 {
			header_up X-Forwarded-Proto https
		}
	}

	# /safety — Streamlit AEO Safety Filter demo (aeogeo-st-safety :8501)
	handle /safety* {
		reverse_proxy host.docker.internal:8501
	}

	# /api/v1 — Spring Boot yoga-api (matching, studios, bookings) when present
	handle /api/v1* {
		reverse_proxy host.docker.internal:19090
	}

	# Provider surface — studio / instructor partner dashboard
	handle /partners* {
		reverse_proxy host.docker.internal:8000 {
			flush_interval -1
			header_up X-Forwarded-Proto https
		}
	}
	# /studio — elbee Studio operator chatbot (FastAPI on host :8000, SSE)
	handle /studio* {
		reverse_proxy host.docker.internal:8000 {
			flush_interval -1
			header_up X-Forwarded-Proto https
		}
	}

	# AEO / SEO — static JSON-LD documents for crawlers (mounted into container)
	handle /.well-known/* {
		root * /srv/well-known
		file_server
	}
	handle /aeo/* {
		root * /srv/aeo
		file_server
	}

	handle /health {
		reverse_proxy host.docker.internal:8000
	}

	# Default — Vite dev server only. No FastAPI fallback: a mixed upstream pool
	# causes some module requests to be served by FastAPI (404) or to fail Vite's
	# host allow-list (403) when the LB rotates after a single slow request.
	handle /* {
		reverse_proxy host.docker.internal:5174 {
			# Vite dev server's host-allowlist trusts its own listening address.
			# Override Host so Vite sees host.docker.internal:5174 instead of
			# the public hostname (which would otherwise trigger a 403).
			header_up Host {http.reverse_proxy.upstream.hostport}
			transport http {
				dial_timeout 2s
				response_header_timeout 30s
			}
		}
	}

	encode zstd gzip

	log {
		output stderr
		format console
	}
}
