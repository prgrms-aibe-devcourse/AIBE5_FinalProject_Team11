# aeogeo — environment variables
# Copy to .env and edit as needed.  Never commit .env to git.

# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=aeogeo
BRAND=elbee.yogaman.club
DEBUG=false

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated) ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,https://aiegoo.github.io,https://elbee.yogaman.club

# ── Ollama LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# ── RAG tuning ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=6000
RAG_MIN_KEYWORD_SCORE=1

# ── Data ───────────────────────────────────────────────────────────────────
DEFAULT_BOOK=generative-engine-optimization
