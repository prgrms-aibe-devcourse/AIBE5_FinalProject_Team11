# aeogeo — environment variables
# Copy to .env and edit as needed.  Never commit .env to git.

# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=aeogeo
BRAND=elbee.yogaman.club
DEBUG=false

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated) ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,https://aiegoo.github.io,https://elbee.yogaman.club

# ── Ollama LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# ── OpenAI fallback (used when Ollama is slow or unavailable) ─────────────
# Provider mode: auto | ollama | openai  (auto = Ollama first, OpenAI on stall/error)
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
# If Ollama emits no token within this many seconds, auto-switch to OpenAI.
OLLAMA_SOFT_DEADLINE=25

# Windows / WSL2 notes:
# If Ollama runs on the Windows host and the API runs in WSL2, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# If native Windows Python cannot find Tesseract, set:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── RAG tuning ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=6000
RAG_MIN_KEYWORD_SCORE=1

# ── Data ───────────────────────────────────────────────────────────────────
DEFAULT_BOOK=generative-engine-optimization

# ── Maps API ───────────────────────────────────────────────────────────────
# Kakao Local API (primary — best for Korean addresses)
#   Sign up: https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_KEY=

# Google Places API (optional fallback)
#   Sign up: https://console.cloud.google.com → Places API → Create key
GOOGLE_PLACES_KEY=

# Which source to use when coord is provided: kakao | google | seed
# "seed" always uses local yoga_locations.json (no API key required)
MAPS_SOURCE=kakao

# How long (seconds) to cache map API responses per location grid cell
MAPS_CACHE_TTL=300
